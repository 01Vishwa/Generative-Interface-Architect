{
  "base": "vs-dark",
  "inherit": true,
  "rules": [
    { "token": "comment", "foreground": "6b7280", "fontStyle": "italic" },
    { "token": "string", "foreground": "34d399" },
    { "token": "string.key.json", "foreground": "93c5fd" },
    { "token": "string.value.json", "foreground": "34d399" },
    { "token": "number", "foreground": "f59e0b" },
    { "token": "keyword", "foreground": "c084fc" },
    { "token": "keyword.json", "foreground": "c084fc" },
    { "token": "delimiter", "foreground": "6b7280" },
    { "token": "delimiter.bracket.json", "foreground": "9ca3af" },
    { "token": "delimiter.colon.json", "foreground": "6b7280" },
    { "token": "delimiter.comma.json", "foreground": "6b7280" },
    { "token": "type", "foreground": "38bdf8" },
    { "token": "variable", "foreground": "e2e8f0" },
    { "token": "constant", "foreground": "f59e0b" },
    { "token": "operator", "foreground": "9ca3af" },
    { "token": "tag", "foreground": "f472b6" },
    { "token": "attribute.name", "foreground": "93c5fd" },
    { "token": "attribute.value", "foreground": "34d399" },
    { "token": "metatag", "foreground": "6b7280" }
  ],
  "colors": {
    "editor.background": "#0a0e1a",
    "editor.foreground": "#e2e8f0",
    "editor.lineHighlightBackground": "#1e293b40",
    "editor.lineHighlightBorder": "#1e293b00",
    "editor.selectionBackground": "#3b82f630",
    "editor.selectionHighlightBackground": "#3b82f615",
    "editor.inactiveSelectionBackground": "#3b82f615",
    "editorLineNumber.foreground": "#374151",
    "editorLineNumber.activeForeground": "#6b7280",
    "editorCursor.foreground": "#3b82f6",
    "editorBracketMatch.background": "#3b82f620",
    "editorBracketMatch.border": "#3b82f650",
    "editorIndentGuide.background": "#1e293b",
    "editorIndentGuide.activeBackground": "#374151",
    "editorWhitespace.foreground": "#1e293b",
    "editorGutter.background": "#0a0e1a",
    "editorGutter.addedBackground": "#22c55e",
    "editorGutter.modifiedBackground": "#3b82f6",
    "editorGutter.deletedBackground": "#ef4444",
    "editorOverviewRuler.border": "#0a0e1a",
    "editorWidget.background": "#111827",
    "editorWidget.border": "#1e293b",
    "editorSuggestWidget.background": "#111827",
    "editorSuggestWidget.border": "#1e293b",
    "editorSuggestWidget.selectedBackground": "#1e293b",
    "editorSuggestWidget.highlightForeground": "#3b82f6",
    "peekView.border": "#3b82f650",
    "peekViewTitle.background": "#111827",
    "peekViewEditor.background": "#0d1117",
    "peekViewResult.background": "#111827",
    "minimap.background": "#0a0e1a",
    "minimapSlider.background": "#3b82f620",
    "minimapSlider.hoverBackground": "#3b82f640",
    "minimapSlider.activeBackground": "#3b82f660",
    "scrollbar.shadow": "#00000000",
    "scrollbarSlider.background": "#37415180",
    "scrollbarSlider.hoverBackground": "#6b728080",
    "scrollbarSlider.activeBackground": "#9ca3af80"
  }
}
